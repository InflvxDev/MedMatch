---
import '../styles/global.css'

interface Props {
	title?: string;
	description?: string;
	/** Ruta de imagen social opcional, relativa al sitio. */
	image?: string;
}

const {
	title = 'MedMatch — Comparador clínico de precios de productos médicos',
	description = 'MedMatch compara precios de productos médicos entre portafolios a partir de tu Excel y resalta el mejor precio para apoyar tus decisiones de compra. Procesamiento 100% en el navegador.',
	image = '/favicon.svg',
} = Astro.props;

// URL canónica auto-referenciada basada en `site` de astro.config.
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const socialImage = new URL(image, Astro.site ?? Astro.url.origin);

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebApplication',
	name: 'MedMatch',
	url: canonicalURL.href,
	description,
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Web',
	inLanguage: 'es',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'COP',
	},
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO primario -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<meta name="theme-color" content="#202a54" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="MedMatch" />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={socialImage} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImage} />

		<!-- Datos estructurados -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="relative min-h-screen overflow-x-hidden bg-surface-100 font-sans text-primary-700 antialiased">
		<!-- Atmósfera: glows radiales suaves -->
		<div
			aria-hidden="true"
			class="pointer-events-none fixed inset-0 -z-30"
			style="background:
				radial-gradient(58rem 58rem at 92% -12%, color-mix(in srgb, var(--color-accent-400) 18%, transparent), transparent 60%),
				radial-gradient(50rem 50rem at -10% 110%, color-mix(in srgb, var(--color-secondary-400) 22%, transparent), transparent 62%),
				linear-gradient(180deg, var(--color-surface-50), var(--color-surface-100) 60%, var(--color-surface-200));"
		>
		</div>
		<!-- Atmósfera: rejilla blueprint -->
		<div aria-hidden="true" class="bg-blueprint pointer-events-none fixed inset-0 -z-20 opacity-60"></div>
		<!-- Atmósfera: grano -->
		<div aria-hidden="true" class="bg-grain pointer-events-none fixed inset-0 -z-10 opacity-[0.025] mix-blend-multiply"></div>

		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
